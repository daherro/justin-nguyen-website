---
interface Props {
  /** texture opacity over the base colour */
  opacity?: number;
  /** vertical scrim gradient for legibility */
  scrim?: string;
}
const {
  opacity = 0.13,
  scrim = 'linear-gradient(180deg, rgba(10,7,6,0.82) 0%, rgba(10,7,6,0.55) 22%, rgba(10,7,6,0.55) 70%, rgba(10,7,6,0.9) 100%)',
} = Astro.props;
---

<div class="ground" aria-hidden="true">
  <div class="base"></div>
  <div class="texture" style={`opacity:${opacity}`}></div>
  <div class="scrim" style={`background:${scrim}`}></div>
</div>

<style>
  .ground { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
  /* Size to the large viewport so the iOS address bar collapsing on scroll
     does not rescale the fixed background. 100vh is the stable fallback. */
  .base,
  .texture,
  .scrim {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100lvh;
    height: var(--vh-stable, 100lvh);
  }
  .base { background: var(--bg); }
  .texture {
    background: url('/assets/lacquer-texture.png') center / cover no-repeat;
  }
  .scrim { z-index: 1; }
</style>

---
// Live raking-light lacquer surface for the homepage hero.
// Ported from the Claude Design prototype (Homepage.dc.html) to vanilla JS.
---

<canvas id="lacquer-canvas" aria-hidden="true"></canvas>
<div class="scrim" aria-hidden="true"></div>

<style>
  #lacquer-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100lvh;
    z-index: 0;
    display: block;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--canvas-fade, 1.4s) ease;
  }
  #lacquer-canvas.is-ready { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    #lacquer-canvas { transition: none; opacity: 1; }
  }
  .scrim {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100lvh;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(8, 6, 5, 0.78) 0%,
      rgba(8, 6, 5, 0.32) 26%,
      rgba(8, 6, 5, 0.3) 56%,
      rgba(8, 6, 5, 0.86) 100%
    );
  }
</style>

<script>
  // The pixel prep (dim/bright/luminance passes + glint scan) is expensive, so
  // it lives at module scope and survives client-side navigations — revisiting
  // the homepage reuses it instead of reprocessing the image.
  type Prep = {
    iw: number;
    ih: number;
    baseDim: HTMLCanvasElement;
    bright: HTMLCanvasElement;
    lumAlpha: HTMLCanvasElement;
    glints: { ix: number; iy: number; l: number; ph: number; sp: number }[];
  };
  let prep: Prep | null = null;
  let imgPromise: Promise<HTMLImageElement> | null = null;
  let cleanup: (() => void) | null = null;

  function loadImage() {
    imgPromise ??= new Promise((resolve, reject) => {
      const im = new Image();
      im.onload = () => resolve(im);
      im.onerror = reject;
      im.src = '/assets/lacquer-texture.webp';
    });
    return imgPromise;
  }

  function prepare(img: HTMLImageElement): Prep {
    const iw = img.naturalWidth;
    const ih = img.naturalHeight;
    // Apply brightness/saturate/contrast in pixel space rather than via
    // ctx.filter, which older iOS Safari/WebKit silently ignores (leaving the
    // base image at full brightness and killing the glow's contrast on mobile).
    const mk = (br: number, sat: number, con: number) => {
      const c = document.createElement('canvas');
      c.width = iw;
      c.height = ih;
      const x = c.getContext('2d')!;
      x.drawImage(img, 0, 0);
      const id = x.getImageData(0, 0, iw, ih);
      const p = id.data;
      for (let i = 0; i < p.length; i += 4) {
        let r = p[i] * br,
          g = p[i + 1] * br,
          b = p[i + 2] * br;
        const lum = 0.2126 * r + 0.7152 * g + 0.0722 * b;
        r = lum + sat * (r - lum);
        g = lum + sat * (g - lum);
        b = lum + sat * (b - lum);
        r = (r - 127.5) * con + 127.5;
        g = (g - 127.5) * con + 127.5;
        b = (b - 127.5) * con + 127.5;
        p[i] = r < 0 ? 0 : r > 255 ? 255 : r;
        p[i + 1] = g < 0 ? 0 : g > 255 ? 255 : g;
        p[i + 2] = b < 0 ? 0 : b > 255 ? 255 : b;
      }
      x.putImageData(id, 0, 0);
      return c;
    };
    const baseDim = mk(0.42, 0.78, 1.04);
    const bright = mk(1.62, 1.42, 1.08);

    const plain = document.createElement('canvas');
    plain.width = iw;
    plain.height = ih;
    const px = plain.getContext('2d')!;
    px.drawImage(img, 0, 0);
    const d = px.getImageData(0, 0, iw, ih).data;
    const lum = document.createElement('canvas');
    lum.width = iw;
    lum.height = ih;
    const lctx = lum.getContext('2d')!;
    const lout = lctx.createImageData(iw, ih);
    const lo = lout.data;
    const glints: Prep['glints'] = [];
    const step = Math.max(8, Math.round(iw / 150));
    for (let y = 0; y < ih; y++) {
      for (let x = 0; x < iw; x++) {
        const i = (y * iw + x) * 4;
        const r = d[i],
          g = d[i + 1],
          b = d[i + 2];
        let L = (0.5 * r + 0.42 * g + 0.08 * b) / 255;
        const warm = Math.max(0, (r + g) / 2 - b) / 255;
        L = Math.min(1, L * (0.72 + 0.7 * warm));
        let a = (L - 0.16) / 0.84;
        a = a < 0 ? 0 : a;
        a = Math.pow(a, 1.25);
        lo[i] = 255;
        lo[i + 1] = 255;
        lo[i + 2] = 255;
        lo[i + 3] = Math.round(a * 255);
      }
    }
    lctx.putImageData(lout, 0, 0);
    for (let y = step; y < ih - step; y += step) {
      for (let x = step; x < iw - step; x += step) {
        const i = (y * iw + x) * 4;
        const r = d[i],
          g = d[i + 1],
          b = d[i + 2];
        const L = (0.5 * r + 0.42 * g + 0.08 * b) / 255;
        const warm = Math.max(0, (r + g) / 2 - b) / 255;
        if (L > 0.5 && warm > 0.12)
          glints.push({ ix: x, iy: y, l: L, ph: Math.random() * 6.28, sp: 0.6 + Math.random() * 1.8 });
      }
    }
    return { iw, ih, baseDim, bright, lumAlpha: lum, glints };
  }

  function boot() {
    cleanup?.();
    cleanup = null;
    const cvs = document.getElementById('lacquer-canvas') as HTMLCanvasElement | null;
    if (!cvs) return;
    const ctx = cvs.getContext('2d')!;
    const reduced =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Touch devices have no cursor to drive the spotlight, so the idle glow on
    // the dark lacquer reads as nothing. Boost its radius and warm bloom there.
    const noHover = window.matchMedia && window.matchMedia('(hover: none)').matches;

    let lx = window.innerWidth * 0.5;
    let ly = window.innerHeight * 0.45;
    let tx = lx;
    let ty = ly;
    let lastMove = -99999;
    let ready = false;
    let raf = 0;
    let alive = true;

    const tmp = document.createElement('canvas');
    const tctx = tmp.getContext('2d')!;
    let W = 0,
      H = 0,
      dpr = 1;
    let cover: { dx: number; dy: number; dw: number; dh: number; s: number };
    let start = performance.now();

    const offs: Array<() => void> = [];
    const on = (type: string, fn: EventListenerOrEventListenerObject) => {
      window.addEventListener(type, fn, { passive: true });
      offs.push(() => window.removeEventListener(type, fn));
    };
    cleanup = () => {
      alive = false;
      cancelAnimationFrame(raf);
      for (const off of offs) off();
    };

    on('pointermove', ((e: PointerEvent) => {
      tx = e.clientX;
      ty = e.clientY;
      lastMove = performance.now();
    }) as EventListener);
    on('touchmove', ((e: TouchEvent) => {
      if (e.touches && e.touches[0]) {
        tx = e.touches[0].clientX;
        ty = e.touches[0].clientY;
        lastMove = performance.now();
      }
    }) as EventListener);
    let rt: ReturnType<typeof setTimeout>;
    on('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(layout, 160);
    });

    function layout() {
      if (!prep || !alive) return;
      // Read the canvas's stable CSS box (100lvh) rather than window.innerHeight,
      // which fluctuates as the iOS address bar shows/hides during scroll.
      const newW = cvs!.clientWidth;
      const newH = cvs!.clientHeight;
      // Skip no-op relayouts so scroll-driven resize events do not clear/rescale the canvas.
      if (newW === W && newH === H && cvs!.width) return;
      dpr = Math.min(window.devicePixelRatio || 1, 1.75);
      W = newW;
      H = newH;
      cvs!.width = W * dpr;
      cvs!.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      tmp.width = W * dpr;
      tmp.height = H * dpr;
      tctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const s = Math.max(W / prep.iw, H / prep.ih);
      const dw = prep.iw * s,
        dh = prep.ih * s;
      cover = { dx: (W - dw) / 2, dy: (H - dh) / 2, dw, dh, s };
    }

    function frame(now: number) {
      if (!alive) return;
      if (!ready || !prep) {
        raf = requestAnimationFrame(frame);
        return;
      }
      const t = (now - start) / 1000;
      const cv = cover;

      // Blend toward the autonomous drift path over ~1.8s once the cursor has
      // been idle for 2.4s (a hard switch here used to make the light lurch).
      const idle = reduced ? 0 : Math.min(1, Math.max(0, (now - lastMove - 2400) / 1800));
      let ax = tx,
        ay = ty;
      if (idle > 0) {
        const wx = W * (0.5 + 0.34 * Math.cos(t * 0.26));
        const wy = H * (0.46 + 0.26 * Math.sin(t * 0.205));
        ax = tx + (wx - tx) * idle;
        ay = ty + (wy - ty) * idle;
      }
      const ease = 0.08 + 0.2 * (1 - idle);
      lx += (ax - lx) * ease;
      ly += (ay - ly) * ease;
      const R = noHover
        ? Math.max(300, Math.min(W, H) * 0.42)
        : Math.max(260, Math.min(W, H) * 0.32);
      const breath = reduced ? 1 : 0.92 + 0.08 * Math.sin(t * 0.9);

      ctx.globalCompositeOperation = 'source-over';
      ctx.clearRect(0, 0, W, H);
      ctx.drawImage(prep.baseDim, cv.dx, cv.dy, cv.dw, cv.dh);

      tctx.globalCompositeOperation = 'source-over';
      tctx.clearRect(0, 0, W, H);
      tctx.drawImage(prep.bright, cv.dx, cv.dy, cv.dw, cv.dh);
      tctx.globalCompositeOperation = 'destination-in';
      const grad = tctx.createRadialGradient(lx, ly, 0, lx, ly, R);
      grad.addColorStop(0, 'rgba(255,255,255,' + 0.95 * breath + ')');
      grad.addColorStop(0.55, 'rgba(255,255,255,' + 0.5 * breath + ')');
      grad.addColorStop(1, 'rgba(255,255,255,0)');
      tctx.fillStyle = grad;
      tctx.fillRect(0, 0, W, H);
      tctx.globalCompositeOperation = 'destination-in';
      tctx.drawImage(prep.lumAlpha, cv.dx, cv.dy, cv.dw, cv.dh);

      ctx.globalCompositeOperation = 'lighter';
      ctx.drawImage(tmp, 0, 0, W, H);

      // Touch devices have no cursor to create a hotspot, so the gold-fleck
      // reveal alone reads as nothing on the dark lacquer. Add a proximity
      // sheen that lights up the whole surface around the drifting light.
      if (noHover) {
        tctx.globalCompositeOperation = 'source-over';
        tctx.clearRect(0, 0, W, H);
        tctx.drawImage(prep.bright, cv.dx, cv.dy, cv.dw, cv.dh);
        tctx.globalCompositeOperation = 'destination-in';
        const sheen = tctx.createRadialGradient(lx, ly, 0, lx, ly, R * 0.82);
        sheen.addColorStop(0, 'rgba(255,255,255,' + 0.45 * breath + ')');
        sheen.addColorStop(1, 'rgba(255,255,255,0)');
        tctx.fillStyle = sheen;
        tctx.fillRect(0, 0, W, H);
        ctx.globalCompositeOperation = 'lighter';
        ctx.globalAlpha = 0.24;
        ctx.drawImage(tmp, 0, 0, W, H);
        ctx.globalAlpha = 1;
      }

      const gr = R * 0.92;
      for (const gp of prep.glints) {
        const vx = cv.dx + gp.ix * cv.s,
          vy = cv.dy + gp.iy * cv.s;
        const dx = lx - vx,
          dy = ly - vy,
          dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > gr) continue;
        const prox = 1 - dist / gr;
        const tw = reduced ? 1 : 0.45 + 0.55 * Math.sin(t * gp.sp + gp.ph);
        const a = prox * prox * tw * (0.5 + 0.5 * gp.l);
        if (a < 0.06) continue;
        const rad = 1.4 + prox * 5.5 * gp.l;
        const g2 = ctx.createRadialGradient(vx, vy, 0, vx, vy, rad);
        g2.addColorStop(0, 'rgba(255,228,150,' + Math.min(0.9, a) + ')');
        g2.addColorStop(0.5, 'rgba(228,184,100,' + a * 0.5 + ')');
        g2.addColorStop(1, 'rgba(228,184,100,0)');
        ctx.fillStyle = g2;
        ctx.beginPath();
        ctx.arc(vx, vy, rad, 0, 6.2832);
        ctx.fill();
      }

      const halo = ctx.createRadialGradient(lx, ly, 0, lx, ly, R * 1.1);
      halo.addColorStop(0, 'rgba(224,180,104,' + (noHover ? 0.08 : 0.05) + ')');
      halo.addColorStop(1, 'rgba(224,180,104,0)');
      ctx.fillStyle = halo;
      ctx.fillRect(0, 0, W, H);
      ctx.globalCompositeOperation = 'source-over';

      raf = requestAnimationFrame(frame);
    }

    // Repeat visits have the prep cached, so use a shorter emergence fade.
    cvs.style.setProperty('--canvas-fade', prep ? '0.6s' : '1.4s');
    loadImage()
      .then((im) => {
        if (!alive) return;
        prep ??= prepare(im);
        layout();
        ready = true;
        cvs.classList.add('is-ready');
      })
      .catch(() => {});
    start = performance.now();
    raf = requestAnimationFrame(frame);
  }

  document.addEventListener('astro:page-load', boot);
  document.addEventListener('astro:before-swap', () => {
    cleanup?.();
    cleanup = null;
  });
</script>

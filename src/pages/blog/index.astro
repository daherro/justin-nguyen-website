---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import StaticBackground from '../../components/StaticBackground.astro';
import { readingMinutes, formatDate } from '../../utils/reading';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const [featured, ...rest] = posts;
---

<BaseLayout
  title="Blog · Justin Nguyễn"
  description="Notes on strategy, technology, and the ideas Justin Nguyễn keeps returning to."
>
  <div class="page">
    <StaticBackground />

    <div class="content">
      <Nav active="blog" variant="flow" />

      <header class="header">
        <div class="eyebrow" data-reveal>Writing</div>
        <h1 data-reveal style="--reveal-delay: 0.08s">Blog</h1>
        <p class="lede" data-reveal style="--reveal-delay: 0.16s">
          Notes on strategy, technology, and the ideas I keep returning to, written to think more
          clearly and shared in case they are useful.
        </p>
        <div class="rule" data-reveal style="--reveal-delay: 0.24s"></div>
      </header>

      {
        featured && (
          <section class="featured-wrap">
            <a href={`/blog/${featured.id}/`} class="featured" data-reveal style="--reveal-delay: 0.28s">
              <div class="meta">
                <span class="eyebrow small">Featured</span>
                <span class="dotsep" />
                <span class="date">{formatDate(featured.data.date)}</span>
              </div>
              <span class="f-title">{featured.data.title}</span>
              <span class="f-standfirst">{featured.data.summary}</span>
              <span class="read">
                Read the essay <span class="arrow">&rarr;</span>
              </span>
            </a>
          </section>
        )
      }

      <section class="index">
        {
          rest.map((post, i) => (
            <a href={`/blog/${post.id}/`} class="row" data-reveal style={`--reveal-delay: ${Math.min(0.34 + i * 0.06, 0.5)}s`}>
              <span class="date col">{formatDate(post.data.date)}</span>
              <span>
                <span class="r-title">{post.data.title}</span>
                <span class="r-sum">{post.data.summary}</span>
              </span>
              <span class="r-aside">
                <span class="chip">{post.data.topic}</span>
                <span class="mins">{readingMinutes(post.body)} min read</span>
              </span>
            </a>
          ))
        }
      </section>

      {posts.length === 0 && <p class="empty">No posts yet. Check back soon.</p>}

      <Footer marginTop="96px" />
    </div>
  </div>
</BaseLayout>

<style>
  .content { position: relative; z-index: 2; }
  .header { max-width: var(--maxw); margin: 0 auto; padding: 110px var(--pad-x) 0 var(--pad-x); }
  .header h1 {
    font-family: var(--font-display);
    margin: 26px 0 0 0;
    padding-bottom: 0.08em;
    font-size: clamp(56px, 8vw, 104px);
    line-height: 1.04;
    font-weight: 600;
    color: var(--ink-bright);
  }
  .lede { margin: 26px 0 0 0; font-size: 21px; line-height: 1.5; font-weight: 300; color: var(--ink-softer); max-width: 640px; }
  .header .rule { margin-top: 56px; }

  .meta { display: flex; gap: 14px; align-items: center; margin-bottom: 18px; }
  .small { font-size: 12px; letter-spacing: 0.14em; }
  .dotsep { width: 4px; height: 4px; border-radius: 50%; background: var(--celadon-deep); }
  .date { font-size: 13.5px; color: var(--muted-deep); font-variant-numeric: tabular-nums; }

  .featured-wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 var(--pad-x); }
  .featured {
    display: block;
    padding: 48px 24px 46px 4px;
    border-bottom: 1px solid var(--rule-soft);
    color: var(--ink-bright);
    transition: color 0.22s ease, padding-left 0.22s ease, background-color 0.22s ease;
  }
  .featured:hover { color: var(--gold); padding-left: 20px; background-color: rgba(227, 184, 100, 0.05); }
  .f-title {
    font-family: var(--font-display);
    font-size: clamp(38px, 5vw, 60px);
    font-weight: 600;
    line-height: 1.06;
    display: block;
    max-width: 840px;
  }
  .f-standfirst {
    display: block;
    margin-top: 20px;
    font-size: 19px;
    line-height: 1.6;
    color: var(--muted-link);
    max-width: 680px;
    font-weight: 300;
  }
  .read { display: inline-flex; align-items: center; gap: 10px; margin-top: 24px; font-size: 15px; color: var(--celadon); }
  .read .arrow { transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1); }
  .featured:hover .read .arrow { transform: translateX(5px); }

  .index { max-width: var(--maxw); margin: 0 auto; padding: 0 var(--pad-x); }
  .row {
    display: grid;
    grid-template-columns: 150px 1fr auto;
    gap: 34px;
    align-items: baseline;
    padding: 32px 20px 32px 4px;
    border-bottom: 1px solid var(--rule-soft);
    color: var(--ink);
    transition: color 0.22s ease, padding-left 0.22s ease, background-color 0.22s ease;
  }
  .row:hover { color: var(--gold); padding-left: 20px; background-color: rgba(227, 184, 100, 0.05); }
  .col { padding-top: 0.6em; }
  .r-title { font-family: var(--font-display); font-size: 32px; font-weight: 600; line-height: 1.12; display: block; }
  .r-sum { display: block; margin-top: 8px; font-size: 16px; line-height: 1.55; color: var(--muted); max-width: 560px; }
  .r-aside { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; padding-top: 0.4em; }
  .mins { font-size: 12.5px; color: var(--muted-deep); }
  .empty { max-width: var(--maxw); margin: 48px auto; padding: 0 var(--pad-x); color: var(--muted); }

  @media (max-width: 640px) {
    .row { grid-template-columns: 1fr; gap: 12px; }
    .r-aside { flex-direction: row; align-items: center; gap: 14px; }
  }
</style>

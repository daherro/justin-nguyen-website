---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StaticBackground from '../components/StaticBackground.astro';
import { projects } from '../data/projects';
---

<BaseLayout
  title="Projects · Justin Nguyễn"
  description="A working record of the things Justin Nguyễn has built, shipped, and run across strategy, product, and the occasional thing made entirely on his own."
>
  <div class="page">
    <StaticBackground />

    <div class="content">
      <Nav active="projects" variant="flow" />

      <header class="header">
        <div class="eyebrow" data-reveal>Selected Work</div>
        <h1 data-reveal style="--reveal-delay: 0.08s">Projects</h1>
        <p class="lede" data-reveal style="--reveal-delay: 0.16s">
          A working record of the things I have built, shipped, and run, across strategy, product,
          and the occasional thing made entirely on my own.
        </p>
        <div class="rule" data-reveal style="--reveal-delay: 0.24s"></div>
      </header>

      <section class="index">
        {
          projects.map((p, i) => {
            const Tag = p.href ? 'a' : 'button';
            const attrs = p.href
              ? { href: p.href, target: '_blank', rel: 'noopener noreferrer' }
              : { type: 'button', 'data-modal-title': p.title, 'data-modal-msg': p.modal };
            return (
              <Tag class="row" data-reveal style={`--reveal-delay: ${Math.min(i * 0.06, 0.3)}s`} {...attrs}>
                <span class="num">{String(i + 1).padStart(2, '0')}</span>
                <span>
                  <span class="title">{p.title}</span>
                  <span class="desc">{p.description}</span>
                  <span class="tags">
                    <span class="chip">{p.category}</span>
                    <span class="chip">{p.year}</span>
                  </span>
                </span>
                <span class="arrow">{p.href ? '↗' : '→'}</span>
              </Tag>
            );
          })
        }
      </section>

      <dialog id="project-modal" class="modal">
        <div class="modal-card">
          <h2 class="modal-title" id="modal-title"></h2>
          <p class="modal-msg" id="modal-msg"></p>
          <button type="button" class="modal-close" id="modal-close">Close</button>
        </div>
      </dialog>

      <Footer marginTop="96px" />
    </div>
  </div>
</BaseLayout>

<style>
  .content { position: relative; z-index: 2; }
  .header { max-width: var(--maxw); margin: 0 auto; padding: 110px var(--pad-x) 0 var(--pad-x); }
  .header h1 {
    font-family: var(--font-display);
    margin: 26px 0 0 0;
    padding-bottom: 0.08em;
    font-size: clamp(56px, 8vw, 104px);
    line-height: 1.04;
    font-weight: 600;
    color: var(--ink-bright);
  }
  .eyebrow { margin-bottom: 0; }
  .header h1 { margin-top: 26px; }
  .lede {
    margin: 26px 0 0 0;
    font-size: 21px;
    line-height: 1.5;
    font-weight: 300;
    color: var(--ink-softer);
    max-width: 640px;
  }
  .header .rule { margin-top: 56px; }

  .index { max-width: var(--maxw); margin: 0 auto; padding: 8px var(--pad-x) 0 var(--pad-x); }
  .row {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 34px;
    align-items: baseline;
    padding: 34px 20px 34px 4px;
    border-bottom: 1px solid var(--rule-soft);
    color: var(--ink);
    transition: color 0.22s ease, padding-left 0.22s ease, background-color 0.22s ease;
    /* resets so <button> rows match <a> rows */
    width: 100%;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    font: inherit;
    text-align: left;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
  }
  .row:hover { color: var(--gold); padding-left: 20px; background-color: rgba(227, 184, 100, 0.05); }
  .row:focus-visible { outline: 1px solid var(--gold); outline-offset: 2px; }
  .num {
    font-size: 16px;
    font-weight: 500;
    opacity: 0.5;
    font-variant-numeric: tabular-nums;
    padding-top: 0.7em;
  }
  .title {
    font-family: var(--font-display);
    font-size: 38px;
    font-weight: 600;
    display: block;
    line-height: 1.1;
  }
  .desc {
    display: block;
    margin-top: 8px;
    font-size: 16px;
    line-height: 1.55;
    color: var(--muted);
    max-width: 560px;
  }
  .tags { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
  .arrow {
    font-size: 22px;
    opacity: 0.6;
    align-self: center;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.28s ease;
  }
  /* external links carry ↗ so they lift up-and-right; modal rows slide right */
  a.row:hover .arrow { transform: translate(4px, -4px); opacity: 1; }
  button.row:hover .arrow { transform: translateX(6px); opacity: 1; }

  @media (max-width: 640px) {
    .row { grid-template-columns: 1fr; gap: 10px; }
    .num { padding-top: 0; }
    .arrow { display: none; }
  }

  /* ===== modal ===== */
  .modal {
    border: none;
    padding: 0;
    background: transparent;
    width: min(480px, calc(100vw - 40px));
    color: var(--ink);
  }
  .modal::backdrop {
    background: rgba(8, 6, 5, 0.72);
    backdrop-filter: blur(2px);
  }
  .modal[open] .modal-card {
    animation: modal-in 0.26s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .modal[open]::backdrop {
    animation: backdrop-in 0.26s ease;
  }
  @keyframes modal-in {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to { opacity: 1; transform: none; }
  }
  @keyframes backdrop-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .modal-card {
    background: #14100c;
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 36px 34px;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.6);
  }
  .modal-title {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 600;
    color: var(--ink-bright);
    margin: 0 0 14px 0;
    line-height: 1.15;
  }
  .modal-msg {
    font-size: 16.5px;
    line-height: 1.62;
    color: var(--ink-softer);
    margin: 0 0 28px 0;
  }
  .modal-close {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: 1px solid rgba(227, 184, 100, 0.45);
    border-radius: 2px;
    color: var(--gold);
    font: inherit;
    font-size: 14px;
    letter-spacing: 0.04em;
    padding: 9px 22px;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .modal-close:hover {
    color: var(--ink-bright);
    border-color: var(--ink-bright);
    background-color: rgba(227, 184, 100, 0.06);
  }
</style>

<script>
  // Re-bind after every client-side navigation: the ClientRouter swaps in a
  // fresh DOM but module scripts only execute once per session.
  function initProjectModal() {
    const dlg = document.getElementById('project-modal') as HTMLDialogElement | null;
    const titleEl = document.getElementById('modal-title');
    const msgEl = document.getElementById('modal-msg');
    if (!dlg || dlg.dataset.bound) return;
    dlg.dataset.bound = 'true';

    document.querySelectorAll<HTMLElement>('[data-modal-msg]').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (titleEl) titleEl.textContent = btn.getAttribute('data-modal-title') || '';
        if (msgEl) msgEl.textContent = btn.getAttribute('data-modal-msg') || '';
        dlg.showModal();
      });
    });
    document.getElementById('modal-close')?.addEventListener('click', () => dlg.close());
    // click on the backdrop (outside the card) closes the dialog
    dlg.addEventListener('click', (e) => {
      if (e.target === dlg) dlg.close();
    });
  }
  // Run immediately as well: in production bundles the initial
  // astro:page-load can fire before this module's listener registers.
  initProjectModal();
  document.addEventListener('astro:page-load', initProjectModal);
</script>
